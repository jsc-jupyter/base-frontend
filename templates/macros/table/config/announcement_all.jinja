{%- import "macros/svgs.jinja" as svg -%}

{%- set show_announcement = true %}
{%- macro announcement() %}
<div class="alert bg-info alert-dismissible fade show" style="color: #023d6b;" role="alert">
  <h4 class="alert-heading">       
    {{ svg.announcement_svg | safe }}
    <span class="align-middle">Issue with container registry affecting Repo2Docker</span>
  </h4>
  We are currently experiencing an issue with the container registry, which may cause some Binder launches or builds to fail.
  Previously built images should still work as expected.
</div>
{%- endmacro %}
