{
  "name": "jupyter-jsc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "tsc -b && vite build --mode development",
    "eslint": "npm run eslint:check -- --fix",
    "eslint:check": "eslint . --cache --ext .ts,.tsx",
    "lint": "npm run eslint && npm run prettier",
    "lint:check": "npm run eslint:check && npm run prettier:check",
    "prettier": "npm run prettier:base -- --write --list-different",
    "prettier:base": "prettier \"{**/*,*}.{ts,tsx,js,jsx,css,html,json}\"",
    "prettier:check": "npm run prettier:base -- --check"
  },
  "dependencies": {
    "bootstrap": "^5.3.3",
    "react": "^19.0.0",
    "react-bootstrap": "^2.10.9",
    "react-dom": "^19.0.0",
    "url-join": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "prettier": "3.5.3",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0",
    "vite-plugin-static-copy": "^2.3.0",
    "vite-plugin-svgr": "^4.3.0"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "arrowParens": "avoid"
  }
}
