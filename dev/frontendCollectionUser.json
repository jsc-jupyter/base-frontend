  "defaultPartitions": {
    "juwels": [
      "juwels_devel",
      "juwels_mem192"
    ],
    "juwels_booster": [
      "juwels_develbooster"
    ],
    "juwels_gpus": [
      "juwels_develgpus"
    ],
    "jureca-dc_cpu": [
      "jureca-dc_cpu-bigmem",
      "jureca-dc_cpu-devel"
    ],
    "jureca-dc_gpu": [
