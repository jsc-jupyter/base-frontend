  "serviceConfig": {
    "JupyterLab": {
      "allowedGroups": [
        "default"
      ],
      "optionsName": "Version",
      "serviceId": "jupyterlab",
      "defaultOption": 4.2,
      "options": {
        "4.3": {
          "name": "JupyterLab - 4.3",
          "mapping": "lmod",
          "kernelSet": "4.3",
          "extensionSet": "4.3",
          "proxySet": "4.3",
          "allowedLists": {
            "groups": [
              "default"
            ],
            "systems": [
              "JURECA",
              "JUWELS",
              "JEDI",
              "JUSUF",
              "DEEP"
            ]
          }
        },
        "4.2": {
          "name": "JupyterLab - 4.2",
          "mapping": "lmod",
          "kernelSet": "4.2",
          "extensionSet": "4.2",
          "proxySet": "4.2",
          "allowedLists": {
            "groups": [
              "default"
            ],
            "systems": [
              "JURECA",
              "JUWELS",
              "JEDI",
              "JUSUF",
              "DEEP",
              "JSC-Cloud",
              "Dummy",
              "LocalDummy"
            ]
          }
        },
        "3.6": {
          "name": "JupyterLab - 3.6",
          "mapping": "lmod",
          "kernelSet": "3.6",
          "extensionSet": "3.6",
          "proxySet": "3.6",
          "allowedLists": {
            "groups": [
              "default"
            ],
            "systems": [
              "JURECA",
              "JUWELS",
              "JUSUF",
              "DEEP",
              "JSC-Cloud"
            ]
          }
        },
        "custom": {
          "name": "Custom Docker image (starting a Jupyter server)",
          "userInput": {
            "required": true,
            "defaultMountEnabled": true,
            "defaultMountPath": "/mnt/userdata"
          },
          "allowedLists": {
            "groups": [
              "default"
            ],
            "systems": [
              "JSC-Cloud",
              "LRZ-Staging",
              "LRZ",
              "MPCDF",
              "LocalDummy",
              "Dummy"
            ]
          }
        },
        "repo2docker": {
          "name": "Repo2docker (Binder)",
          "userInput": {
            "isRepo2Docker": true
          },
          "allowedLists": {
            "groups": [
              "default"
            ],
            "systems": [
              "JSC-Cloud",
              "LocalDummy",
              "Dummy"
            ]
          }
        }
      }
    }
  },
